<?xml version ='1.0'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name ="arduinobot">
<xacro:property name ="PI" value="3.14159265" />
<xacro:property name ="effort" value="30" />
<xacro:property name ="velocity" value="10" />
<xacro:macro name="inertial_default" params="mass">
    <inertial>
        <mass value="1" />
        <inertia ixx="1.0" ixy="0.0" ixz="0.0"
                iyy="1.0" iyz="0.0"
                izz="1.0" />
    </inertial>
</xacro:macro>
    <link name ="world"/>
    <link name ="base_link">
        <xacro:inertial_default mass="1.0"/>
        <visual>
            <origin rpy ="0 0 0" xyz="-0.5 -0.5 0" />
            <geometry>
                <mesh filename ="package://arduinobot_description/meshes/basement.STL" scale ="0.01 0.01 0.01"/>
            </geometry>
        </visual>
        <collision>
        <origin rpy ="0 0 0" xyz="-0.5 -0.5 0" />
            <geometry>
                <mesh filename ="package://arduinobot_description/meshes/basement.STL" scale ="0.01 0.01 0.01"/>
            </geometry>

        </collision>
    </link>
    <joint name ="world_base_joint" type ="fixed">
        <parent link ="world"/>
        <child link ="base_link"/>
        <origin rpy ="0 0 0" xyz ="0 0 0" />
    </joint>
    <link name = "basement_link">
        <xacro:inertial_default mass="0.1"/>
            <visual>
                <origin rpy ="0 0 0" xyz = "-0.39 -0.39 -0.56" />
            <geometry>
                <mesh filename ="package://arduinobot_description/meshes/base_plate.STL" scale ="0.01 0.01 0.01" />
            
            </geometry>
            </visual>
            <collision>
                <origin rpy ="0 0 0" xyz = "-0.39 -0.39 -0.56" />
            <geometry>
                <mesh filename ="package://arduinobot_description/meshes/base_plate.STL" scale ="0.01 0.01 0.01" />
            
            </geometry>
            </collision>
    </link>
    <joint name ="base_basement_joint" type="revolute">
        <parent link ="base_link" />
        <child link="basement_link" />
        <axis xyz="0 0 1"/>
        <origin rpy="0 0 0" xyz="0 0 0.307" />
        <limit lower = "-${PI/2}" upper = "${PI/2}" effort="${effort}" velocity ="${velocity}" />
    </joint>
    <link name="forward_arm_link">
    <xacro:inertial_default mass="0.1"/>
    <visual>
        <origin rpy ="0 -${PI/2} ${PI/2}" xyz="0.19 0.06 -0.08" />
        <geometry>
            <mesh filename="package://arduinobot_description/meshes/forward_drive_arm.STL" scale ="0.01 0.01 0.01"/>
        </geometry>
    </visual>
    <collision>
        <origin rpy ="0 -${PI/2} ${PI/2}" xyz="0.19 0.06 -0.08" />
        <geometry>
            <mesh filename="package://arduinobot_description/meshes/forward_drive_arm.STL" scale ="0.01 0.01 0.01"/>
        </geometry>

    </collision>
    </link>
    <joint name="basement_forward_arm_joint" type="revolute">
        <parent link ="basement_link" />
        <child link ="forward_arm_link" />
        <axis xyz="1 0 0" />
        <origin rpy ="0 0 0" xyz="-0.02 0 0.35" />
        <limit lower ="-${PI/2}" upper ="${PI/2}" effort ="${effort}" velocity="${velocity}" />
    
    </joint>
    <link name ="horizontal_arm_link">
        <xacro:inertial_default mass="0.1"/>
        <visual>
            <origin rpy = "${PI/2} 0 ${PI/2}" xyz="-0.03 -0.4 -0.06" />
            <geometry>
                <mesh filename="package://arduinobot_description/meshes/horizontal_arm.STL" scale="0.01 0.01 0.01"/>
            </geometry>
        </visual>
        <collision>
            <origin rpy = "${PI/2} 0 ${PI/2}" xyz="-0.03 -0.4 -0.06" />
            <geometry>
                <mesh filename="package://arduinobot_description/meshes/horizontal_arm.STL" scale="0.01 0.01 0.01"/>
            </geometry>

        </collision>
    </link>
    <joint name ="forward_horizontal_arm_joint" type="revolute">
        <parent link="forward_arm_link" />
        <child link ="horizontal_arm_link" />
        <origin rpy ="0 0 0" xyz="0 0 0.8" />
        <axis xyz ="1 0 0" />
        <limit lower ="-${PI/2}" upper="${PI/2}" effort="${effort}" velocity="${velocity}" />
    </joint>
    <link name ="claw_support_link">
    <xacro:inertial_default mass="0.05"/>
    <visual>
        <origin rpy="0 0 ${PI/2}" xyz="0 -0.05 -0.15" />
        <geometry>
            <mesh filename="package://arduinobot_description/meshes/claw_support.STL" scale="0.01 0.01 0.01" />
        </geometry>
    </visual>
    <collision>
        <origin rpy="0 0 ${PI/2}" xyz="0 -0.05 -0.15" />
        <geometry>
            <mesh filename="package://arduinobot_description/meshes/claw_support.STL" scale="0.01 0.01 0.01" />
        </geometry>
    </collision>
    </link>
    <joint name ="horizontal_claw_joint" type="fixed">
        <parent link="horizontal_arm_link" />
        <child link ="claw_support_link" />
        <origin rpy ="0 0 0" xyz="0 0.82 0" />
        
    </joint>
    <link name="griper_right">
    <xacro:inertial_default mass="0.01"/>
    <visual>
        <origin rpy="0 0 -${PI/2}" xyz="-0.1 0.5 -0.1" />
        <geometry>
            <mesh filename="package://arduinobot_description/meshes/right_finger.STL" scale="0.01 0.01 0.01" />
        </geometry>
    </visual>
    <collision>
        <origin rpy="0 0 -${PI/2}" xyz="-0.1 0.5 -0.1" />
        <geometry>
            <mesh filename="package://arduinobot_description/meshes/right_finger.STL" scale="0.01 0.01 0.01" />
        </geometry>

    </collision>
    </link>
    <link name="griper_left">
    <xacro:inertial_default mass="0.01"/>
    <visual>
        <origin rpy="0 0 -${PI/2}" xyz="-0.04 0.5 -0.1" />
        <geometry>
            <mesh filename="package://arduinobot_description/meshes/left_finger.STL" scale="0.01 0.01 0.01" />
        </geometry>
    </visual>
    <collision>
        <origin rpy="0 0 -${PI/2}" xyz="-0.04 0.5 -0.1" />
        <geometry>
            <mesh filename="package://arduinobot_description/meshes/left_finger.STL" scale="0.01 0.01 0.01" />
        </geometry>

    </collision>
    </link>
    <joint name="right_joint" type ="revolute">
        <origin rpy="0 0 0" xyz="-0.04 0.13 -0.1" />
        <parent link ="claw_support_link" />
        <child link="griper_right"/>
        <axis xyz="0 0 1" />
        <limit lower="-${PI/2}" upper="0" effort="${effort}" velocity="${velocity}" />
    </joint>
    <joint name="left_joint" type ="revolute">
        <origin rpy="0 0 0" xyz="-0.22 0.13 -0.1" />
        <parent link ="claw_support_link" />
        <child link="griper_left"/>
        <axis xyz="0 0 1" />
        <mimic joint="right_joint" multiplier="-1"/>
        <limit lower="0" upper="${PI/2}" effort="${effort}" velocity="${velocity}" />
    </joint>
    <link name="rgb_camera_link">
    <xacro:inertial_default mass="0.05"/>
        <visual>
            <origin rpy="-${PI/2} 0 0" xyz ="0.03 0.25 0.1" />
            <geometry>
                <mesh filename="package://arduinobot_description/meshes/pi_camera.STL" scale="0.01 0.01 0.01"/>
            </geometry>
        </visual>
        <collision>
            <origin rpy="-${PI/2} 0 0" xyz ="0.03 0.25 0.1" />
            <geometry>
                <mesh filename="package://arduinobot_description/meshes/pi_camera.STL" scale="0.01 0.01 0.01"/>
            </geometry>

        </collision>
    </link>
    <joint name="base_rgb_camera_joint" type="fixed">
        <parent link="base_link" />
        <child link ="rgb_camera_link" />
        <origin rpy="0.280 0 0" xyz="-0.17 0.1 0.15" />
    </joint>
</robot>
